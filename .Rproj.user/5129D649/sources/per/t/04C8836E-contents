
library(shiny)

function(input, output) {
  
  output$summary <- renderPrint({
    cat("Time of walk:", input$time_of_walk, "\n")
    cat("Human participants:", paste(input$human_participants, collapse = ", "), "\n")
    cat("Canine participants:", paste(input$canine_participants, collapse = ", "), "\n")
  })
  
}
